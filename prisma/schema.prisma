generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id                Int         @id @default(autoincrement())
  email             String      @unique
  password          String
  name              String?
  role              String
  location          String?
  isVerified        Boolean     @default(false)
  verifyToken       String?
  campaignsCreated  Campaign[]
  campaignsJoined   Campaign[]  @relation("CampaignParticipants")
  groupsCreated     Group[]
  groupsJoined      Group[]     @relation("GroupMembers")
  messages          Message[]
  fundraisers       Fundraiser[]
  donations         Donation[]
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

model Sensor {
  id          Int           @id @default(autoincrement())
  type        String
  location    String
  lat         Float?
  lon         Float?
  status      String        @default("active")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  data        SensorData[]
  alerts      Alert[]
}

model SensorData {
  id        Int      @id @default(autoincrement())
  sensorId  Int
  sensor    Sensor   @relation(fields: [sensorId], references: [id])
  value     Float
  timestamp DateTime @default(now())
}

model Alert {
  id        Int      @id @default(autoincrement())
  type      String
  message   String
  sensorId  Int?
  sensor    Sensor?  @relation(fields: [sensorId], references: [id])
  timestamp DateTime @default(now())
}

model Campaign {
  id            Int      @id @default(autoincrement())
  title         String
  description   String
  creatorId     Int
  creator       User     @relation(fields: [creatorId], references: [id])
  participants  User[]   @relation("CampaignParticipants")
  createdAt     DateTime @default(now())
}

model Group {
  id        Int       @id @default(autoincrement())
  name      String
  issue     String
  creatorId Int
  creator   User      @relation(fields: [creatorId], references: [id])
  members   User[]    @relation("GroupMembers")
  messages  Message[]
  createdAt DateTime  @default(now())
}

model Message {
  id        Int      @id @default(autoincrement())
  content   String
  groupId   Int
  group     Group    @relation(fields: [groupId], references: [id])
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model Fundraiser {
  id          Int        @id @default(autoincrement())
  cause       String
  description String
  goal        Float
  raised      Float      @default(0)
  creatorId   Int
  creator     User       @relation(fields: [creatorId], references: [id])
  donations   Donation[]
  createdAt   DateTime   @default(now())
}

model Donation {
  id           Int        @id @default(autoincrement())
  amount       Float
  method       String
  status       String     @default("completed")
  fundraiserId Int
  fundraiser   Fundraiser @relation(fields: [fundraiserId], references: [id])
  userId       Int
  user         User       @relation(fields: [userId], references: [id])
  createdAt    DateTime   @default(now())
}

model News {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  source    String
  createdAt DateTime @default(now())
}
